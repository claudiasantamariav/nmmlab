	journal = {Neuron},
	keywords = {Activating Transcription Factor 1 Animals Behavior/physiology Brain/anatomy \& histology/physiology Cyclic AMP Response Element-Binding Protein/genetics/*metabolism *DNA-Binding Proteins Enkephalins/genetics/metabolism Female Hippocampus/anatomy \& histology/*physiology Humans In Situ Hybridization Long-Term Potentiation/physiology Male Maze Learning Memory/*physiology Mice Mice, Genetic Transgenes, Transgenic Neuronal Plasticity/physiology Protein Precursors/genetics/metabolism Transcription Factors/genetics/*metabolism Transcription},
	number = {3},
