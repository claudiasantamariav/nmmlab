	keywords = {Animals Biophysical Phenomena Biophysics Cell Membrane/physiology Electrophysiology Evoked Potentials Female Hippocampus/*physiology Male Rats *Synaptic Transmission},
	number = {1-2},
	pages = {292--5},
	title = {Evidence for neuronal interactions by electrical field effects in the {CA3} and dentate regions of rat hippocampal slices},
	volume = {367},
