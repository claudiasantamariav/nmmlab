@article{ninomiya_microcircuitry_2015,
	abstract = {Neocortex is striking in its laminar architecture. Tracer studies have uncovered anatomical connectivity among laminae, but the functional connectivity between laminar compartments is still largely unknown. Such functional connectivity can be discerned through spontaneous neural correlations during rest. Previous work demonstrated a robust pattern of mesoscopic resting-state connectivity in macaque primary visual cortex (V1) through interlaminar cross-frequency coupling. Here we investigated whether this pattern generalizes to other cortical areas by comparing resting-state laminar connectivity between V1 and the supplementary eye field (SEF), a frontal area lacking a granular layer 4 (L4). Local field potentials (LFPs) were recorded with linear microelectrode arrays from all laminae of granular V1 and agranular SEF while monkeys rested in darkness. We found substantial differences in the relationship between the amplitude of gamma-band ({\textbackslash}textbackslashtextgreater30 Hz) LFP and the phase of alpha-band (7-14 Hz) LFP between these areas. In V1, gamma amplitudes in L2/3 and L5 were coupled with alpha-band LFP phase in L5, as previously described. In contrast, in SEF phase-amplitude coupling was prominent within L3 and much weaker across layers. These results suggest that laminar interactions in agranular SEF are unlike those in granular V1. Thus the intrinsic functional connectivity of the cortical microcircuit does not seem to generalize across cortical areas.},
	author = {Ninomiya, Taihei and Dougherty, Kacie and Godlove, David C. and Schall, Jeffrey D. and Maier, Alexander},
	date-added = {2021-07-28 14:16:23 +0200},
	date-modified = {2021-07-28 14:16:23 +0200},
	doi = {10.1152/jn.00624.2014},
	issn = {1522-1598},
	journal = {Journal of Neurophysiology},
	keywords = {Action Potentials, Animals, Macaca mulatta, Magnetic Resonance Imaging, Neurons, Brain Mapping, Male, Nerve Net, Female, Frontal Lobe, phase-amplitude coupling, spontaneous activity, canonical microcircuit, cortical column, cross-frequency coupling, Microelectrodes, Occipital Lobe, ongoing activity, Spectrum Analysis, Visual Pathways},
	language = {eng},
	month = may,
	number = {9},
	pages = {3242--3255},
	pmcid = {PMC4440241},
	pmid = {25744881},
	shorttitle = {Microcircuitry of agranular frontal cortex},
	title = {Microcircuitry of agranular frontal cortex: contrasting laminar connectivity between occipital and frontal areas},
	volume = {113},
	year = {2015},
	Bdsk-Url-1 = {https://doi.org/10.1152/jn.00624.2014}}

