	keywords = {Animals Brain/pathology/*physiology Brain Diseases/etiology/pathology *Magnetics/adverse effects Rats/*physiology},
	pages = {180--5},
	title = {Repetitive high magnetic field stimulation: the effect upon rat brain},
	volume = {43},
	year = {1991}}

