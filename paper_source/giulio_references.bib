	keywords = {Adult Aged Electric Stimulation/methods Electromagnetic Phenomena Electromyography Humans Middle Aged Motor Cortex/*physiology Reaction Time/physiology},
	number = {1},
	pages = {121--7},
	title = {Comparison of descending volleys evoked by monophasic and biphasic magnetic stimulation of the motor cortex in conscious humans},
	volume = {141},
	year = {2001}}

