@inproceedings{ilmoniemi_transcranial_1998,
	abstract = {We have developed frameless stereotaxy for applying TMS to a given spot in the brain as determined by MRI. We have used high-resolution EEG (HR-EEG) with 60 channels to monitor and locate the TMS-induced activity so that excitability of the different portions of the cortex and connectivity between different areas can be mapped reliably. By using dipole modeling and minimum-norm estimation, we have observed both ipsi- and contralateral spreading of neuronal activity after a TMS pulse. We have also demonstrated that TMS stimulation can affect the dynamics of sensory evoked auditory and somatosensory potentials. We expect that the combination of TMS and HR-EEG will offer a powefil tool for basic neuroscience and for clinical diagnosis, for example in the assessment of brain connectivity in patients suffering from neurodegenerative diseases or head injuries.},
	author = {Ilmoniemi, Risto J. and al, et},
	booktitle = {Proceedings of the 20th {Annual} {International} {Conference} of the {IEEE} {Engineering} in {Medicine} and {Biology} {Society}},
