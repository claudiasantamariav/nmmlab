@article{francis_sensitivity_2003,
	abstract = {Weak electric fields modulate neuronal activity, and knowledge of the interaction threshold is important in the understanding of neuronal synchronization, in neural prosthetic design, and in the public health assessment of environmental extremely low frequency fields. Previous experimental measurements have placed the threshold between 1 and 5 mV/mm, although theory predicts that elongated neurons should have submillivolt per millimeter sensitivity near 100 microV/mm. We here provide the first experimental confirmation that neuronal networks are detectably sensitive to submillivolt per millimeter electrical fields [Gaussian pulses 26 msec full width at half-maximal, 140 microV/mm root mean square (rms), 295 microV/mm peak amplitude], an order of magnitude below previous findings, and further demonstrate that these networks are more sensitive than the average single neuron threshold (185 microV/mm rms, 394 microV/mm peak amplitude) to field modulation.},
	author = {Francis, J. T. and Gluckman, B. J. and Schiff, S. J.},
	date-added = {2021-07-28 14:16:23 +0200},
	date-modified = {2021-07-28 14:16:23 +0200},
	journal = {J Neurosci},
	keywords = {Sprague-Dawley, Action Potentials Animals Cells, Cultured Electric Stimulation *Electricity Nerve Net Neurons/*physiology Pyramidal Cells/cytology/*physiology Rats Rats},
	number = {19},
	pages = {7255--61},
	title = {Sensitivity of neurons to weak electric fields},
	volume = {23},
	year = {2003}}

