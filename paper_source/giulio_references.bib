@article{rigaud_tissue_1994,
	abstract = {Two experimental set-ups for in vitro characterization of electrical bio-impedance are described. The first one, based on a commercially available instrument, operates in the frequency range 1 Hz-10 MHz. The second one uses an identification process and operates in the frequency range 1 Hz-1 MHz. Some results are presented and discussed in the context of multifrequency electrical impedance tomography.},
