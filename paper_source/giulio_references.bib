@techreport{ruffini_interaction_2008,
	abstract = {This note aims to clarify several aspects of bioelectric phenomena with a focus on stimulation of a single neuron. When an electromagnetic field is coupled to a neuron, whether TMS or tDCS, the interaction is through the induced electric field and the neuron and surrounding conductive medium. We will elucidate the mechanisms for interaction and salient points to guide further work, including theoretical/numerical work with neuronal ensembles, experimental work and system design. {\textbackslash}textbackslashmedskip Here we will provide: {\textbackslash}textbackslashbeginenumerate ıtem A brief review of the origin of bioelectric potentials (mostly based on TN00011) ıtem The derivation of the cable equation for a generic bent neuron ıtem A discussion of termination boundary conditions ıtem Analysis of the interaction of external fields with single neurons in steady state ıtem 2D simulations in steady state ıtem An analytic 1D solution with many key elements ıtem An overview of neuron modeling and compartment models and how to include stimulation in them ıtem A review of the state of the art in neuron electro-magnetic stimulation ıtem A review of EM boundary conditions {\textbackslash}textbackslashendenumerate We provide a set of conclusions for discussion.},
	author = {Ruffini, Giulio},
	date-added = {2021-07-28 14:16:23 +0200},
	date-modified = {2021-07-28 14:16:23 +0200},
