	keywords = {Electric Stimulation/instrumentation/*methods *Electromagnetic Fields Human Photic Stimulation/instrumentation/methods Support, Non-U.S. Gov't Visual Cortex/*physiology Visual Fields/physiology},
	number = {1},
	pages = {128--32},
	title = {Transcranial magnetic stimulation. {Which} part of the current waveform causes the stimulation?},
	volume = {141},
	year = {2001}}

