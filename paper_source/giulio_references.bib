@techreport{ruffini_stimulation_2009,
	abstract = {As part of discussions on how to improve transcranial stimulation control and specificity and to guide future in-vivo and in-vitro experimental work, the possibility of exploiting resonance phenomena in neurons (single or small populations) and larger scales (brain) has been discussed at Starlab. Starting with a definition of entrainment, synchronization, resonance and stochastic resonance, we here provide a review of the literature with a focus on experimental evidence for resonance in the brain (sensorial, electrical stimulation), in-vitro (electrical, ultrasonic) and in-silico (models for electrical effects). We provide a set of conclusions for discussion and highlight the fact that although clearly both resonance and stochastic resonance phenomena are relevant mechanisms in neural systems and can play an important role in stimulation technology, models that can explain their effects are for the time being mostly developed at the single neuron level, and that less is known of the interaction at larger scales involving a large number of interconnected neurons. Future experimental work could probe this area in silico, in vitro, in vivo and ex vivo. In general, electrical stimulation experiments forcing synchronous activity in different brain areas using periodic and random signals could seek to replicate the results of sensorial stimulation experiments. In particular, hierarchical stimulation schemes could be designed to explore the relationships between oscillatory behavior at different spatial and temporal scales.},
	author = {Ruffini, Giulio and Grau, Carles},
	date-added = {2021-07-28 14:16:23 +0200},
	date-modified = {2021-07-28 14:16:23 +0200},
	institution = {Starlab Barcelona S.L.},
	month = feb,
	number = {TN00164},
	title = {Stimulation and resonance phenomena in the brain},
	type = {Starlab {Technical} {Note}},
	year = {2009}}

