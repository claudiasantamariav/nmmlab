@article{ruohonen_theory_1999,
	abstract = {Human excitable cells can be stimulated noninvasively with externally applied time-varying electromagnetic fields. The stimulation can be achieved either by directly driving current into the tissue (electrical stimulation) or by means of electro-magnetic induction (magnetic stimulation). While the electrical stimulation of the peripheral neuromuscular system has many beneficial applications, peripheral magnetic stimulation has so far only a few. This paper analyzes theoretically the use of multiple magnetic stimulation coils to better control the excitation and also to eventually mimic electrical stimulation. Multiple coils allow electronic spatial adjustment of the shape and location of the stimulus without moving the coils. The new properties may enable unforeseen uses for peripheral magnetic stimulation, e.g., in rehabilitation of patients with neuromuscular impairment.},
	author = {Ruohonen, J. and Ravazzani, P. and Grandori, F. and Ilmoniemi, R. J.},
	date-added = {2021-07-28 14:16:23 +0200},
	date-modified = {2021-07-28 14:16:23 +0200},
	journal = {IEEE Trans Biomed Eng},
	keywords = {Non-U.S. Gov't Time Factors, Axons/physiology Electric Stimulation Therapy/*instrumentation/*methods *Electromagnetic Fields Human Magnetics/*instrumentation/*therapeutic use *Models, Neurological Neuromuscular Diseases/physiopathology/*rehabilitation Peripheral Nerves/physiology Reproducibility of Results Support},
	number = {6},
	pages = {646--51},
	title = {Theory of multichannel magnetic stimulation: toward functional neuromuscular rehabilitation},
	volume = {46},
	year = {1999}}

