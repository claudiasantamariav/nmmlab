@article{fregni_technology_2007,
	abstract = {The use of brain stimulation for the treatment of neurological diseases such as chronic pain, Parkinson's disease, stroke and epilepsy has attracted growing attention. In this article, Fregni and Pascual-Leone review the recent literature regarding the use of two noninvasive brain stimulation techniques: repetitive transcranial magnetic stimulation and transcranial direct current stimulation. The authors discuss the underlying principles and present examples illustrating the therapeutic potential of these two techniques.},
