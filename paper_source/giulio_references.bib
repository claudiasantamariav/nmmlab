@article{cartee_transient_1992,
	abstract = {The effect of extracellular stimulation on excitable tissue is evaluated using analytical models. Primary emphasis is placed on the determination of the rate of rise of the membrane potential in response to subthreshold stimulation. Three models are studied: 1) a spherical cell in a uniform electric field, 2) an infinite cylindrical fiber with a point source stimulus, and 3) a finite length cable with sealed ends and a stimulus electrode at each end.},
